---
import SkillTag from "./SkillTag.astro";

import type { CollectionEntry } from "astro:content";

interface Props {
  experience: CollectionEntry<"experience">;
}

const { experience } = Astro.props;
---

<div class="grid md:grid-cols-[2fr_3fr] gap-16 items-start">
  <div class="flex flex-col gap-12 sticky top-32">
    <div>
      <h3 class="text-2xl font-bold uppercase">
        {experience.data.organization}
      </h3>
      <p class="text-lg">{experience.data.title}</p>
      <p class="text-lg">{experience.data.date}</p>
      <p class="text-lg">{experience.data.location}</p>
    </div>
    <ul class="flex flex-wrap gap-2">
      {
        experience.data.skills.map((skill) => (
          <li>
            <SkillTag skill={skill} />
          </li>
        ))
      }
    </ul>
  </div>
  <div>
    <ul class="list-disc">
      {experience.data.description.map((description) => <li>{description}</li>)}
    </ul>
  </div>
</div>
