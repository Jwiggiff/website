<div class="ipod">
  <div class="screen"></div>
  <div class="wheel">
    <span class="top">menu</span>
    <span class="bottom">
      <img
        src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2d/Play_Pause_icon_2283501.svg/1200px-Play_Pause_icon_2283501.svg.png"
        alt="play/pause"
      />
    </span>
    <span class="left">
      <img
        src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/83/Fast_forward_font_awesome.svg/1200px-Fast_forward_font_awesome.svg.png"
        alt="rw"
      />
    </span>
    <span class="right">
      <img
        src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/83/Fast_forward_font_awesome.svg/1200px-Fast_forward_font_awesome.svg.png"
        alt="ff"
      />
    </span>
  </div>
</div>

<style>
  :root {
    --scale: 1rem;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    height: 100vh;
    display: grid;
    place-items: center;
    background: #222;
    font-family: sans-serif;
  }

  .ipod {
    aspect-ratio: 5/8;
    width: calc(20 * var(--scale));
    border-radius: calc(1.5 * var(--scale));
    background-color: #ccc;
    background-image: radial-gradient(
      circle at 100% 0,
      white,
      rgba(0, 0, 0, 0.25)
    );

    display: grid;
    position: relative;

    &::before {
      content: "";
      position: absolute;
      width: 100%;
      height: calc(100% + 0.5 * var(--scale));
      top: 0;
      left: 0;
      z-index: -1;
      background-color: #666;
      border-radius: inherit;
      box-shadow: 0 calc(0.3 * var(--scale)) calc(1 * var(--scale))
        calc(0.6 * var(--scale)) rgba(0, 0, 0, 0.7);
    }
  }

  .screen {
    aspect-ratio: 5/4;
    width: 75%;
    margin-top: calc(1.5 * var(--scale));
    place-self: start center;
    background-color: #797d65;
    border-radius: calc(0.5 * var(--scale));
    box-shadow: 0 calc(0.25 * var(--scale)) calc(1 * var(--scale))
      rgba(0, 0, 0, 1) inset;
  }

  .wheel {
    aspect-ratio: 1/1;
    border-radius: 50%;
    place-self: start center;
    width: 80%;
    position: relative;
    display: grid;
    place-items: center;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background-image:
        radial-gradient(
          closest-side at center,
          #ccc 80%,
          rgba(0, 0, 0, 0.25) 80%,
          transparent 82%
        ),
        conic-gradient(
          transparent 45deg,
          black 45deg,
          transparent 45.5deg,
          transparent 135deg,
          black 135deg,
          transparent 136deg,
          transparent 225deg,
          black 225deg,
          transparent 226deg,
          transparent 315deg,
          black 315deg,
          transparent 316deg
        ),
        radial-gradient(closest-side at center, #ccc 80%, white 90%, #ccc);
    }

    &::after {
      content: "";
      position: absolute;
      inset: calc(5.5 * var(--scale));
      border-radius: inherit;
      background-image: radial-gradient(
        circle at 75% 25%,
        rgba(255, 255, 255, 0.5) 70%,
        rgba(0, 0, 0, 0.25)
      );
      box-shadow:
        0 0 calc(0.25 * var(--scale)) 0 rgba(0, 0, 0, 0.5),
        0 0 calc(0.1 * var(--scale)) 0 black inset;
    }

    span {
      font-size: 0.8em;
      position: absolute;
      display: block;
      font-weight: bold;
      opacity: 0.2;

      img {
        height: 1em;
      }

      &.top {
        top: calc(0.4 * var(--scale));
      }
      &.bottom {
        font-size: 1.1em;
        bottom: calc(0 * var(--scale));
      }
      &.left {
        scale: -1 1;
        left: calc(0.4 * var(--scale));
      }
      &.right {
        right: calc(0.4 * var(--scale));
      }
    }
  }
</style>
